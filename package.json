{
  "name": "inventory",
  "version": "1.0.0",
  "description": "inve",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"wait-on tcp:5173 tcp:3001 && electron .\"",
    "start": "electron .",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "package": "npm run build && electron-builder build --win",
    "dev:backend": "node server_dev.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElAmirr/inventory.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ElAmirr/inventory/issues"
  },
  "homepage": "https://github.com/ElAmirr/inventory#readme",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.elamirr.inventory",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist-electron"
    }
  }
}